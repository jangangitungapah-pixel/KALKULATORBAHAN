<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:KALKULATORBAHAN.ViewModels"
        mc:Ignorable="d"
        x:Class="KALKULATORBAHAN.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1480"
        Height="920"
        MinWidth="1160"
        MinHeight="760"
        Background="{DynamicResource AppShellBrush}"
        Icon="/Assets/avalonia-logo.ico"
        Title="Kalkulator Modal &amp; HPP F&amp;B">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="Border.cardAlt">
            <Setter Property="Background" Value="{DynamicResource AppCardAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
        <Style Selector="TextBlock.sectionEyebrow">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentTextBrush}" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        </Style>
        <Style Selector="Border.pill">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource AppCardAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Border.chartBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Background" Value="{DynamicResource AppAccentTextBrush}" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Height="64"
                Padding="18,10"
                Background="{DynamicResource AppCardBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,360,*,Auto" ColumnSpacing="16" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="36"
                            Height="36"
                            CornerRadius="10"
                            Background="{DynamicResource AppAccentSoftBrush}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Text="Rp" />
                    </Border>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="KalkulatorBahan" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBox Watermark="Search ingredients, recipes, products..."
                             Text="{Binding GlobalSearchText}" />
                    <Border Classes="cardAlt"
                            Padding="14"
                            IsVisible="{Binding HasGlobalSearchResults}">
                        <StackPanel Spacing="10">
                            <StackPanel IsVisible="{Binding HasSearchIngredientResults}" Spacing="6">
                                <TextBlock Classes="sectionEyebrow" Text="Ingredients" />
                                <ItemsControl ItemsSource="{Binding SearchIngredients}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding HasSearchRecipeResults}" Spacing="6">
                                <TextBlock Classes="sectionEyebrow" Text="Recipes" />
                                <ItemsControl ItemsSource="{Binding SearchRecipes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RecipeViewModel">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding HasSearchProductResults}" Spacing="6">
                                <TextBlock Classes="sectionEyebrow" Text="Products" />
                                <ItemsControl ItemsSource="{Binding SearchProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProductViewModel">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="3" Classes="pill">
                    <StackPanel Spacing="2">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding BusinessName}" />
                        <TextBlock Classes="muted"
                                   FontSize="11"
                                   Text="{Binding IngredientAlert}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ui:NavigationView x:Name="RootNavigation"
                               CompactModeThresholdWidth="1100"
                               CompactPaneLength="76"
                               ExpandedModeThresholdWidth="1340"
                               IsBackButtonVisible="False"
                               IsPaneOpen="{Binding IsNavigationPaneOpen, Mode=TwoWay}"
                               IsPaneToggleButtonVisible="True"
                               IsSettingsVisible="False"
                               OpenPaneLength="296"
                               PaneDisplayMode="LeftCompact"
                               SelectionChanged="OnNavigationSelectionChanged">
        <ui:NavigationView.PaneHeader>
            <Border Margin="12,6,12,12"
                    Padding="16"
                    Classes="cardAlt">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="KalkulatorBahan" />
                    <TextBlock Classes="muted"
                               FontSize="12"
                               Text="Costing F&amp;B yang ringkas." />
                </StackPanel>
            </Border>
        </ui:NavigationView.PaneHeader>

        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem x:Name="DashboardItem"
                                   Tag="dashboard"
                                   Content="Ringkasan">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Home" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem x:Name="IngredientsItem"
                                   Tag="ingredients"
                                   Content="Bahan">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Library" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem x:Name="RecipesItem"
                                   Tag="recipes"
                                   Content="Resep">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Calculator" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="products"
                                   Content="Produk">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Home" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="costing"
                                   Content="Kalkulasi HPP">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Calculator" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="planner"
                                   Content="Production Planner">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Calendar" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="analytics"
                                   Content="Analitik">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Home" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="suppliers"
                                   Content="Supplier">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Library" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="reports"
                                   Content="Reports">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Document" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Tag="settings"
                                   Content="Pengaturan">
                <ui:NavigationViewItem.IconSource>
                    <ui:SymbolIconSource Symbol="Library" />
                </ui:NavigationViewItem.IconSource>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <ui:NavigationView.PaneFooter>
            <TextBlock Margin="16,0,16,16"
                       Classes="muted"
                       FontSize="11"
                       Text="Avalonia desktop" />
        </ui:NavigationView.PaneFooter>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32" Spacing="24">
                <Border Padding="30"
                        Classes="card">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="sectionEyebrow" Text="Workspace" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentSectionTitle}" />
                            <TextBlock Classes="muted"
                                       FontSize="14"
                                       Text="{Binding CurrentSectionDescription}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="14" Classes="cardAlt" VerticalAlignment="Center">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="Resep aktif" />
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{Binding RecipeName}" />
                                <TextBlock Classes="muted"
                                           FontSize="12"
                                           Text="{Binding HighlightNarrative}"
                                           TextWrapping="Wrap"
                                           Width="240" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <WrapPanel ItemWidth="255" Orientation="Horizontal">
                    <Border Padding="22" Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="Total bahan" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding TotalIngredients}" />
                            <TextBlock Classes="muted"
                                       Text="Daftar bahan yang siap dipakai ke resep." />
                        </StackPanel>
                    </Border>
                    <Border Padding="22" Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="Total resep" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding TotalRecipes}" />
                            <TextBlock Classes="muted"
                                       Text="Resep aktif yang siap dipaketkan jadi produk." />
                        </StackPanel>
                    </Border>
                    <Border Padding="22" Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="Total produk" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding TotalProducts}" />
                            <TextBlock Classes="muted"
                                       Text="Produk jual yang sudah punya struktur biaya." />
                        </StackPanel>
                    </Border>
                    <Border Padding="22" Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="Average HPP" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding AverageHpp, StringFormat='Rp {0:N0}'}" />
                            <TextBlock Classes="muted"
                                       Text="Rata-rata HPP dari semua produk aktif." />
                        </StackPanel>
                    </Border>
                    <Border Padding="22" Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="Suppliers" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Text="{Binding TotalSuppliers}" />
                            <TextBlock Classes="muted"
                                       Text="Jumlah supplier aktif yang memasok database bahan." />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Padding="24" Classes="card" IsVisible="{Binding IsOnboardingVisible}">
                    <StackPanel Spacing="16">
                        <TextBlock Classes="sectionEyebrow" Text="First Time Setup" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding OnboardingTitle}" />
                        <TextBlock Classes="muted" Text="{Binding OnboardingSubtitle}" TextWrapping="Wrap" />

                        <StackPanel Spacing="12" IsVisible="{Binding IsWelcomeStep}">
                            <TextBlock Text="Flow yang akan Anda jalani: setup usaha, tambah bahan, lalu lanjut ke resep dan produk." TextWrapping="Wrap" />
                            <Button Command="{Binding NextOnboardingCommand}" HorizontalAlignment="Left">Mulai Setup</Button>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16" IsVisible="{Binding IsBusinessSetupStep}">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Nama usaha" />
                                <TextBox Text="{Binding BusinessName}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Jenis usaha" />
                                <TextBox Text="{Binding BusinessType}" />
                            </StackPanel>
                            <StackPanel Grid.ColumnSpan="2" Margin="0,92,0,0" Spacing="8">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="sectionEyebrow" Text="Currency" />
                                        <TextBox Text="{Binding Currency}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Classes="sectionEyebrow" Text="Satuan default" />
                                        <TextBox Text="{Binding DefaultUnit}" />
                                    </StackPanel>
                                </Grid>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Command="{Binding PreviousOnboardingCommand}">Kembali</Button>
                                    <Button Command="{Binding NextOnboardingCommand}">Lanjut</Button>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="12" IsVisible="{Binding IsIngredientSetupStep}">
                            <TextBlock Text="Tambahkan bahan pertama Anda sekarang. Setelah tersimpan, onboarding akan selesai otomatis." TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding AddIngredientCommand}">Tambah bahan pertama</Button>
                                <Button Command="{Binding CompleteOnboardingCommand}">Lewati dulu</Button>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="1.05*,1.15*" ColumnSpacing="24" IsVisible="{Binding IsDashboardSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="18">
                            <Border Padding="20" Classes="cardAlt">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="sectionEyebrow" Text="Ringkasan sistem" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Text="Master bahan terpisah dari resep" />
                                    <TextBlock FontSize="14"
                                               Text="{Binding FormulaSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Alur kerja" />
                                    <TextBlock Text="1. Simpan semua bahan di halaman Bahan dengan isi per pack dan harga per pack." TextWrapping="Wrap" />
                                    <TextBlock Text="2. Di halaman Resep, pilih bahan dari master lalu isi kuantitas pemakaian." TextWrapping="Wrap" />
                                    <TextBlock Text="3. Modal bahan, total modal, dan HPP akan mengikuti data master secara otomatis." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="18">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Resep aktif" />
                            <Border Padding="18" Classes="cardAlt">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding RecipeName}" />
                                        <TextBlock Classes="muted"
                                                   Text="{Binding RecipeIngredientCount, StringFormat='Menggunakan {0} bahan dari master'}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                                        <TextBlock Classes="muted"
                                                   HorizontalAlignment="Right"
                                                   Text="Total modal" />
                                        <TextBlock FontSize="20"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding TotalModal, StringFormat='Rp {0:N0}'}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding RecipeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RecipeIngredientItemViewModel">
                                        <Border Margin="0,0,0,12" Padding="18" Classes="cardAlt">
                                            <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="18">
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding IngredientName}" />
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding UsageSummary, StringFormat='Pemakaian: {0}'}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            Spacing="4">
                                                    <TextBlock Classes="muted"
                                                               HorizontalAlignment="Right"
                                                               Text="Modal" />
                                                    <TextBlock FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               Text="{Binding UsageCost, StringFormat='Rp {0:N0}'}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="340,*,320" ColumnSpacing="24" IsVisible="{Binding IsRecipesSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock Classes="sectionEyebrow" Text="Recipe Library" />
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Pilih resep aktif" />
                            <TextBlock Classes="muted"
                                       Text="Library di kiri dipakai untuk memilih resep, sedangkan panel editor di kanan dipakai untuk meracik formula."
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="muted"
                                       FontSize="12"
                                       Text="Pilih resep, edit formula, lalu lihat cost summary secara live." />

                            <DataGrid ItemsSource="{Binding Recipes}"
                                      SelectedItem="{Binding SelectedRecipe}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      MinHeight="300"
                                      RowHeight="56">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Recipe" Width="2*" Binding="{Binding Name}" />
                                    <DataGridTextColumn Header="Yield" Width="1*" Binding="{Binding YieldQuantity, StringFormat={}{0:N0}}" />
                                    <DataGridTextColumn Header="Cost/Unit" Width="1.1*" Binding="{Binding CostPerUnit, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTextColumn Header="Updated" Width="0.9*" Binding="{Binding UpdatedLabel}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding AddRecipeCommand}">Buat resep</Button>
                                <Button Command="{Binding DuplicateSelectedRecipeCommand}">Clone recipe</Button>
                            </WrapPanel>

                            <Border Padding="18" Classes="cardAlt">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Active Recipe" />
                                        <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding RecipeName}" />
                                        <TextBlock Text="{Binding RecipeIngredientCount, StringFormat='Menggunakan {0} bahan aktif'}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Text="Current HPP" />
                                        <TextBlock FontSize="24"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding HppPerPortion, StringFormat='Rp {0:N0}'}" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   Text="{Binding PortionCount, StringFormat='Yield {0:N0} pcs'}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="14">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recipe Identity" />
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="sectionEyebrow" Text="Nama resep" />
                                        <TextBox Text="{Binding RecipeName}" Watermark="Contoh: Matcha Latte 1 batch" />
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Yield dasar" />
                                            <NumericUpDown FormatString="N0"
                                                           Increment="1"
                                                           Minimum="0"
                                                           Value="{Binding SelectedRecipe.YieldQuantity}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Target batch" />
                                            <NumericUpDown FormatString="N0"
                                                           Increment="1"
                                                           Minimum="0"
                                                           Value="{Binding PortionCount}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Kategori" />
                                            <TextBox Text="{Binding SelectedRecipe.Category}" Watermark="Donat / Minuman / Roti" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="sectionEyebrow" Text="Deskripsi" />
                                        <TextBox Text="{Binding SelectedRecipe.Description}" Watermark="Catatan resep singkat" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="14">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Operational Cost" />
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Packaging" />
                                            <NumericUpDown FormatString="N0"
                                                           Increment="100"
                                                           Minimum="0"
                                                           Value="{Binding SelectedRecipe.PackagingCost}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Labor" />
                                            <NumericUpDown FormatString="N0"
                                                           Increment="100"
                                                           Minimum="0"
                                                           Value="{Binding SelectedRecipe.LaborCost}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="8">
                                            <TextBlock Classes="sectionEyebrow" Text="Overhead" />
                                            <NumericUpDown FormatString="N0"
                                                           Increment="100"
                                                           Minimum="0"
                                                           Value="{Binding SelectedRecipe.OverheadCost}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="12">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Ingredient Input" />
                                    <ComboBox ItemsSource="{Binding Ingredients}"
                                              SelectedItem="{Binding SelectedCatalogIngredient}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Classes="muted"
                                                               FontSize="11"
                                                               Text="{Binding PackSummary, StringFormat='Isi pack: {0}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Command="{Binding AddSelectedIngredientToRecipeCommand}">+ Add Ingredient</Button>
                                        <Button Command="{Binding QuickCreateIngredientCommand}">+ Create Ingredient</Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="18">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Ingredient Table" />
                                    <TextBlock Classes="muted"
                                               Text="{Binding RecipeIngredientCount, StringFormat='Workspace ini memuat {0} bahan aktif untuk resep terpilih.'}" />
                                </StackPanel>
                                <Border Grid.Column="1" Classes="pill">
                                    <TextBlock Text="{Binding TotalModal, StringFormat='Total Rp {0:N0}'}" />
                                </Border>
                            </Grid>
                            <TextBlock Classes="muted"
                                       FontSize="12"
                                       Text="Gunakan handle drag untuk mengubah urutan formula." />
                            <DataGrid ItemsSource="{Binding RecipeItems}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      MinHeight="620"
                                      RowHeight="72">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Ingredient" Width="2.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:RecipeIngredientItemViewModel">
                                                <Border Margin="0,6"
                                                        Padding="10,8"
                                                        CornerRadius="14"
                                                        AttachedToVisualTree="OnRecipeIngredientDropTargetAttached"
                                                        DetachedFromVisualTree="OnRecipeIngredientDropTargetDetached">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                        <Border Padding="8,6"
                                                                Background="{DynamicResource AppAccentSoftBrush}"
                                                                CornerRadius="10"
                                                                PointerPressed="OnRecipeIngredientDragStart">
                                                            <TextBlock FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Text="DRAG" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding IngredientName}" />
                                                            <TextBlock Classes="muted"
                                                                       FontSize="11"
                                                                       Text="Diambil dari master bahan" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Unit"
                                                        Width="0.9*"
                                                        Binding="{Binding UnitName}" />
                                    <DataGridTextColumn Header="Unit Cost"
                                                        Width="1.2*"
                                                        Binding="{Binding CostPerUnit, StringFormat='Rp {0:N2}'}" />
                                    <DataGridTextColumn Header="Qty"
                                                        Width="1*"
                                                        Binding="{Binding UsageQuantity, StringFormat={}{0:N2}}" />
                                    <DataGridTemplateColumn Header="Adjust Qty" Width="1.5*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:RecipeIngredientItemViewModel">
                                                <StackPanel Margin="0,8" Spacing="6">
                                                    <NumericUpDown FormatString="N2"
                                                                   Increment="1"
                                                                   Minimum="0"
                                                                   Value="{Binding UsageQuantity}" />
                                                    <TextBlock Classes="muted"
                                                               FontSize="11"
                                                               Text="{Binding UsageSummary}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Total"
                                                        Width="1.2*"
                                                        Binding="{Binding UsageCost, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTemplateColumn Header="Aksi" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:RecipeIngredientItemViewModel">
                                                <Button Command="{Binding RemoveCommand}">
                                                    Hapus
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="24" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock Classes="sectionEyebrow" Text="Sticky Summary" />
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="Live Cost Summary" />

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="Total Recipe Cost" />
                                    <TextBlock FontSize="30"
                                               FontWeight="Bold"
                                               Text="{Binding TotalModal, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Text="{Binding HppPerPortion, StringFormat='Cost per unit: Rp {0:N0}'}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                                    <TextBlock Text="Ingredient Cost" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalRecipeIngredientCost, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Grid.Row="1" Text="Packaging" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRecipePackagingCost, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Grid.Row="2" Text="Labor" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRecipeLaborCost, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Grid.Row="3" Text="Overhead" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedRecipeOverheadCost, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Grid.Row="4" Text="Yield" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PortionCount, StringFormat='{}{0:N0} pcs'}" />
                                    <TextBlock Grid.Row="5" FontWeight="SemiBold" Text="Scaled Batch" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" FontWeight="SemiBold" Text="{Binding SelectedRecipeScaledCost, StringFormat='Rp {0:N0}'}" />
                                </Grid>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Builder Notes" />
                                    <TextBlock Classes="muted"
                                               Text="Panel kanan ini dibuat tetap ringkas agar HPP, yield, dan scaled batch bisa dipantau tanpa kehilangan fokus saat mengedit formula."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="1.6*,0.9*" ColumnSpacing="24" IsVisible="{Binding IsIngredientsSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="18">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="10">
                                <Button Command="{Binding AddIngredientCommand}">+ Add Ingredient</Button>
                                <Button Grid.Column="1">Import</Button>
                                <Button Grid.Column="2">Export</Button>
                                <Button Grid.Column="3">Bulk Edit</Button>
                            </Grid>

                            <TextBox Text="{Binding IngredientSearchText}"
                                     Watermark="Search ingredients..." />

                            <DataGrid ItemsSource="{Binding FilteredIngredients}"
                                      SelectedItem="{Binding SelectedCatalogIngredient}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      MinHeight="660"
                                      RowHeight="64">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Name" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <TextBox Text="{Binding Name}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Category" Width="1.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <TextBox Text="{Binding Category}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Unit" Width="0.8*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <TextBox Text="{Binding UnitName}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Price" Width="1.1*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <NumericUpDown FormatString="N0"
                                                               Increment="500"
                                                               Minimum="0"
                                                               Value="{Binding PackPrice}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Supplier" Width="1.4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <TextBox Text="{Binding SupplierName}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Used In"
                                                        Width="1*"
                                                        Binding="{Binding UsedInSummary}" />
                                    <DataGridTextColumn Header="Update"
                                                        Width="0.9*"
                                                        Binding="{Binding UpdatedLabel}" />
                                    <DataGridTemplateColumn Header="Aksi" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:IngredientCostItemViewModel">
                                                <Button Command="{Binding RemoveCommand}">Hapus</Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="18">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Ingredient Detail" />
                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedCatalogIngredient.Name}" />
                                    <TextBlock Text="{Binding SelectedCatalogIngredient.Category, StringFormat='Category: {0}'}" />
                                    <TextBlock Text="{Binding SelectedCatalogIngredient.UnitName, StringFormat='Unit: {0}'}" />
                                    <TextBlock Text="{Binding SelectedCatalogIngredient.PackPrice, StringFormat='Price: Rp {0:N0}'}" />
                                    <TextBlock Text="{Binding SelectedCatalogIngredient.SupplierName, StringFormat='Supplier: {0}'}" />
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Used In Recipes" />
                                    <ItemsControl ItemsSource="{Binding SelectedIngredientRecipeNames}"
                                                  IsVisible="{Binding HasSelectedIngredientRecipes}" />
                                    <TextBlock Classes="muted"
                                               Text="Klik baris bahan untuk melihat resep terkait dan histori harga." />
                                </StackPanel>
                            </Border>

                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Price History Chart" />
                                    <ItemsControl ItemsSource="{Binding SelectedIngredientHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:BarDataItemViewModel">
                                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="10" Margin="0,2">
                                                    <TextBlock Text="{Binding Label}" />
                                                    <Border Grid.Column="1"
                                                            Classes="chartBar"
                                                            Width="{Binding BarWidth}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="380,*" ColumnSpacing="24" IsVisible="{Binding IsProductsSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Produk" />
                            <DataGrid ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      HeadersVisibility="Column"
                                      Height="170">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produk" Width="2*" Binding="{Binding Name}" />
                                    <DataGridTextColumn Header="Recipe" Width="1.4*" Binding="{Binding PrimaryRecipeName}" />
                                    <DataGridTextColumn Header="HPP" Width="1*" Binding="{Binding HppPerUnit, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTextColumn Header="Harga jual" Width="1.2*" Binding="{Binding SuggestedSellingPrice, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTextColumn Header="Margin" Width="0.9*" Binding="{Binding MarginLabel}" />
                                    <DataGridTemplateColumn Header="Aksi" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:ProductViewModel">
                                                <Button Command="{Binding RemoveCommand}">Hapus</Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Command="{Binding AddProductCommand}" HorizontalAlignment="Left">Buat produk</Button>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Nama produk" />
                                    <TextBox Text="{Binding SelectedProduct.Name}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Kategori" />
                                    <TextBox Text="{Binding SelectedProduct.Category}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Output unit" />
                                    <NumericUpDown FormatString="N0" Increment="1" Minimum="0" Value="{Binding SelectedProduct.OutputUnits}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Margin default" />
                                    <NumericUpDown FormatString="N0" Increment="1" Minimum="0" Maximum="95" Value="{Binding SelectedProduct.DefaultMarginPercent}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Kemasan" />
                                    <NumericUpDown FormatString="N0" Increment="100" Minimum="0" Value="{Binding SelectedProduct.PackagingCost}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Tenaga kerja" />
                                    <NumericUpDown FormatString="N0" Increment="100" Minimum="0" Value="{Binding SelectedProduct.LaborCost}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Overhead" />
                                    <NumericUpDown FormatString="N0" Increment="100" Minimum="0" Value="{Binding SelectedProduct.OverheadCost}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Tambah resep ke produk" />
                                <ComboBox ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipeForProduct}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RecipeViewModel">
                                            <StackPanel Spacing="2">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Classes="muted"
                                                           FontSize="11"
                                                           Text="{Binding BaseCost, StringFormat='Biaya dasar: Rp {0:N0}'}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <Button Command="{Binding AddSelectedRecipeToProductCommand}" HorizontalAlignment="Left">Masukkan resep ke produk</Button>
                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Ringkasan produk terpilih" />
                                    <TextBlock Text="{Binding SelectedProduct.TotalCost, StringFormat='Total cost: Rp {0:N0}'}" />
                                    <TextBlock Text="{Binding SelectedProduct.HppPerUnit, StringFormat='HPP per unit: Rp {0:N0}'}" />
                                    <TextBlock Text="{Binding SelectedProduct.SuggestedSellingPrice, StringFormat='Harga jual default: Rp {0:N0}'}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Komponen produk" />
                            <DataGrid ItemsSource="{Binding SelectedProduct.Components}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      HeadersVisibility="Column"
                                      MinHeight="620">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Resep" Width="2*" Binding="{Binding RecipeName}" />
                                    <DataGridTextColumn Header="Yield" Width="1.2*" Binding="{Binding YieldSummary}" />
                                    <DataGridTextColumn Header="Biaya resep" Width="1.2*" Binding="{Binding BaseRecipeCost, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTemplateColumn Header="Qty" Width="1*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:ProductRecipeComponentViewModel">
                                                <NumericUpDown FormatString="N2" Increment="0.5" Minimum="0" Value="{Binding Multiplier}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Total" Width="1.2*" Binding="{Binding ComponentCost, StringFormat='Rp {0:N0}'}" />
                                    <DataGridTemplateColumn Header="Aksi" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="vm:ProductRecipeComponentViewModel">
                                                <Button Command="{Binding RemoveCommand}">Hapus</Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="360,*" ColumnSpacing="24" IsVisible="{Binding IsCostingSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Kalkulasi HPP" />
                            <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProductViewModel">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Classes="muted"
                                                       FontSize="11"
                                                       Text="{Binding HppPerUnit, StringFormat='HPP: Rp {0:N0}'}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="sectionEyebrow" Text="Metode pricing" />
                                    <ComboBox ItemsSource="{Binding PricingMethods}" SelectedItem="{Binding PricingMethod}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8" IsVisible="{Binding IsMarginMode}">
                                    <TextBlock Classes="sectionEyebrow" Text="Margin %" />
                                    <NumericUpDown FormatString="N0" Increment="1" Minimum="0" Maximum="95" Value="{Binding MarginPercentInput}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="8" IsVisible="{Binding IsMarkupMode}">
                                <TextBlock Classes="sectionEyebrow" Text="Markup %" />
                                <NumericUpDown FormatString="N0" Increment="1" Minimum="0" Value="{Binding MarkupPercentInput}" />
                            </StackPanel>
                            <StackPanel Spacing="8" IsVisible="{Binding IsTargetProfitMode}">
                                <TextBlock Classes="sectionEyebrow" Text="Target profit per unit" />
                                <NumericUpDown FormatString="N0" Increment="100" Minimum="0" Value="{Binding TargetProfitPerUnitInput}" />
                            </StackPanel>
                            <Border Padding="18" Classes="cardAlt">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Harga jual rekomendasi" />
                                    <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding SuggestedSellingPrice, StringFormat='Rp {0:N0}'}" />
                                    <TextBlock Classes="muted" Text="{Binding PricingInsight}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Breakdown biaya" />
                            <WrapPanel ItemWidth="230">
                                <Border Padding="18" Classes="cardAlt"><StackPanel Spacing="6"><TextBlock Classes="sectionEyebrow" Text="Bahan" /><TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedProductIngredientCost, StringFormat='Rp {0:N0}'}" /></StackPanel></Border>
                                <Border Padding="18" Classes="cardAlt"><StackPanel Spacing="6"><TextBlock Classes="sectionEyebrow" Text="Kemasan" /><TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedProductPackagingCost, StringFormat='Rp {0:N0}'}" /></StackPanel></Border>
                                <Border Padding="18" Classes="cardAlt"><StackPanel Spacing="6"><TextBlock Classes="sectionEyebrow" Text="Tenaga kerja" /><TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedProductLaborCost, StringFormat='Rp {0:N0}'}" /></StackPanel></Border>
                                <Border Padding="18" Classes="cardAlt"><StackPanel Spacing="6"><TextBlock Classes="sectionEyebrow" Text="Overhead" /><TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedProductOverheadCost, StringFormat='Rp {0:N0}'}" /></StackPanel></Border>
                            </WrapPanel>
                            <DataGrid ItemsSource="{Binding SelectedProduct.Components}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      HeadersVisibility="Column"
                                      Height="250"
                                      RowHeight="64">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Komponen" Width="2*" Binding="{Binding RecipeName}" />
                                    <DataGridTextColumn Header="Yield" Width="1.1*" Binding="{Binding YieldSummary}" />
                                    <DataGridTextColumn Header="Qty" Width="0.8*" Binding="{Binding Multiplier, StringFormat={}{0:N2}}" />
                                    <DataGridTextColumn Header="Cost" Width="1.2*" Binding="{Binding ComponentCost, StringFormat='Rp {0:N0}'}" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Padding="20" Classes="cardAlt">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding SelectedProductTotalCost, StringFormat='Total cost: Rp {0:N0}'}" />
                                    <TextBlock Text="{Binding SelectedProductHpp, StringFormat='HPP per unit: Rp {0:N0}'}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="360,*" ColumnSpacing="24" IsVisible="{Binding IsPlannerSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Production Planner" />
                            <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProductViewModel">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Target Production" />
                                <NumericUpDown FormatString="N0"
                                               Increment="10"
                                               Minimum="0"
                                               Value="{Binding PlannerTargetProduction}" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Waste %" />
                                <NumericUpDown FormatString="N0"
                                               Increment="1"
                                               Minimum="0"
                                               Value="{Binding WastePercentage}" />
                            </StackPanel>
                            <Border Padding="18" Classes="cardAlt">
                                <TextBlock Text="{Binding PlannerNarrative}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Ingredient Requirement" />
                            <DataGrid ItemsSource="{Binding PlannerRequirements}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      HeadersVisibility="Column"
                                      MinHeight="620">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ingredient" Width="2*" Binding="{Binding IngredientName}" />
                                    <DataGridTextColumn Header="Required Qty" Width="1.4*" Binding="{Binding QuantityText}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="24" IsVisible="{Binding IsAnalyticsSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Ingredient Usage" />
                            <ItemsControl ItemsSource="{Binding IngredientUsageBars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BarDataItemViewModel">
                                        <Grid ColumnDefinitions="110,*,Auto" ColumnSpacing="10" Margin="0,2">
                                            <TextBlock Text="{Binding Label}" />
                                            <Border Grid.Column="1" Classes="chartBar" Width="{Binding BarWidth}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Padding="18" Classes="cardAlt"><TextBlock Text="{Binding IngredientAlert}" TextWrapping="Wrap" /></Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Product Profitability" />
                            <ItemsControl ItemsSource="{Binding ProductProfitBars}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BarDataItemViewModel">
                                        <Grid ColumnDefinitions="110,*,Auto" ColumnSpacing="10" Margin="0,2">
                                            <TextBlock Text="{Binding Label}" />
                                            <Border Grid.Column="1" Classes="chartBar" Width="{Binding BarWidth}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Padding="18" Classes="cardAlt"><TextBlock Text="{Binding MarginAlert}" TextWrapping="Wrap" /></Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="320,*" ColumnSpacing="24" IsVisible="{Binding IsSuppliersSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Supplier" />
                            <Button Command="{Binding AddSupplierCommand}" HorizontalAlignment="Left">Tambah supplier</Button>
                            <Border Padding="18" Classes="cardAlt">
                                <TextBlock Classes="muted" Text="Simpan supplier utama supaya sourcing bahan lebih mudah ditelusuri." TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Daftar supplier" />
                            <DataGrid ItemsSource="{Binding Suppliers}"
                                      SelectedItem="{Binding SelectedSupplier}"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"
                                      HeadersVisibility="Column"
                                      MinHeight="620">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Supplier" Width="1.8*"><DataGridTemplateColumn.CellTemplate><DataTemplate x:DataType="vm:SupplierItemViewModel"><TextBox Text="{Binding Name}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ingredients" Width="0.9*" Binding="{Binding IngredientCount}" />
                                    <DataGridTextColumn Header="Avg Price" Width="1*" Binding="{Binding AveragePriceBand}" />
                                    <DataGridTextColumn Header="Rating" Width="0.9*" Binding="{Binding RatingStars}" />
                                    <DataGridTemplateColumn Header="Telepon" Width="1.2*"><DataGridTemplateColumn.CellTemplate><DataTemplate x:DataType="vm:SupplierItemViewModel"><TextBox Text="{Binding Phone}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Lead time" Width="0.9*"><DataGridTemplateColumn.CellTemplate><DataTemplate x:DataType="vm:SupplierItemViewModel"><NumericUpDown FormatString="N0" Increment="1" Minimum="0" Value="{Binding LeadTimeDays}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Catatan" Width="1.8*"><DataGridTemplateColumn.CellTemplate><DataTemplate x:DataType="vm:SupplierItemViewModel"><TextBox Text="{Binding Notes}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Aksi" Width="Auto"><DataGridTemplateColumn.CellTemplate><DataTemplate x:DataType="vm:SupplierItemViewModel"><Button Command="{Binding RemoveCommand}">Hapus</Button></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="24" IsVisible="{Binding IsReportsSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Reports" />
                            <Button HorizontalAlignment="Left">Export HPP Report</Button>
                            <Button HorizontalAlignment="Left">Export Ingredient Cost Report</Button>
                            <Button HorizontalAlignment="Left">Export Product Profit Report</Button>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Format" />
                            <ComboBox ItemsSource="{Binding ReportFormats}" SelectedItem="{Binding ReportFormat}" />
                            <Border Padding="18" Classes="cardAlt">
                                <TextBlock Text="{Binding ReportFormat, StringFormat='Laporan akan disiapkan dalam format {0}.'}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="24" IsVisible="{Binding IsSettingsSelected}">
                    <Border Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Business Settings" />
                            <StackPanel Spacing="8"><TextBlock Classes="sectionEyebrow" Text="Nama usaha" /><TextBox Text="{Binding BusinessName}" /></StackPanel>
                            <StackPanel Spacing="8"><TextBlock Classes="sectionEyebrow" Text="Jenis usaha" /><TextBox Text="{Binding BusinessType}" /></StackPanel>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <StackPanel Spacing="8"><TextBlock Classes="sectionEyebrow" Text="Currency" /><TextBox Text="{Binding Currency}" /></StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8"><TextBlock Classes="sectionEyebrow" Text="Satuan default" /><TextBox Text="{Binding DefaultUnit}" /></StackPanel>
                            </Grid>
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Waste Percentage" />
                                <NumericUpDown FormatString="N0"
                                               Increment="1"
                                               Minimum="0"
                                               Value="{Binding WastePercentage}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="28" Classes="card">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Appearance &amp; Data" />
                            <StackPanel Spacing="8">
                                <TextBlock Classes="sectionEyebrow" Text="Theme" />
                                <ComboBox ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding ThemeMode}" />
                            </StackPanel>
                            <Border Padding="18" Classes="cardAlt"><TextBlock Text="Backup" /></Border>
                            <Border Padding="18" Classes="cardAlt"><TextBlock Text="Restore" /></Border>
                            <Border Padding="18" Classes="cardAlt"><TextBlock Text="Export / Import" /></Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
            </ui:NavigationView>

            <StackPanel HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,28,28"
                        Spacing="12">
                <Border Classes="card"
                        Padding="18"
                        IsVisible="{Binding IsQuickAddOpen}">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="+ Quick Add" />
                        <Button Command="{Binding AddIngredientCommand}">Ingredient</Button>
                        <Button Command="{Binding AddRecipeCommand}">Recipe</Button>
                        <Button Command="{Binding AddProductCommand}">Product</Button>
                        <Button Command="{Binding AddSupplierCommand}">Supplier</Button>
                    </StackPanel>
                </Border>
                <Button Command="{Binding ToggleQuickAddCommand}"
                        HorizontalAlignment="Right">
                    + Quick Add
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
